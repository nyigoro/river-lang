{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RIVER-LANG Channel Graph AST (Draft)",
  "type": "object",
  "required": ["epoch", "nodes", "flows"],
  "properties": {
    "epoch": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "sector": { "type": "string" }
        }
      }
    },
    "flows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "guard": { "type": "string" }
        }
      }
    }
  }
}