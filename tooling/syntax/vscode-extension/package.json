{
  "name": "river-lang-syntax",
  "displayName": "RIVER-LANG Syntax",
  "description": "Syntax highlighting support for RIVER-LANG (.rasm) files.",
  "version": "0.1.0",
  "publisher": "river-lang",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyigoro/river-lang.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:rasm"
  ],
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "build": "npm --prefix ../../lsp run build && node ./scripts/copy-server.js && tsc -p .",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "rasm",
        "aliases": [
          "RVR-ASM",
          "rasm"
        ],
        "extensions": [
          ".rasm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rasm",
        "scopeName": "source.rasm",
        "path": "../river-lang.tmLanguage.json"
      }
    ]
  }
}
